# Copy to .env and fill in. NEVER commit the real .env.

# --- Data source (Kaggle), used by `movierec-load` ---
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key
MOVIEREC_DATASET=tmdb/tmdb-movie-metadata

# --- Ranking ---
# Final score = blend_alpha * content_similarity + (1 - blend_alpha) * popularity.
MOVIEREC_BLEND_ALPHA=0.7
MOVIEREC_VOTE_COUNT_QUANTILE=0.80

# --- Optional poster images ---
# Without a key, the API returns poster_url=null and the UI shows placeholders.
MOVIEREC_TMDB_API_KEY=

# --- API ---
MOVIEREC_RATE_LIMIT=60/minute
MOVIEREC_LOG_LEVEL=INFO
